# =============================================================================
# Password Strength Auditor - Environment Configuration Example
# =============================================================================
# Copy this file to .env and customize as needed
# NEVER commit .env files with real values to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json
# Options: simple, json

# -----------------------------------------------------------------------------
# API Configuration - HaveIBeenPwned
# -----------------------------------------------------------------------------
HIBP_API_TIMEOUT=5
# Request timeout in seconds (default: 5)
HIBP_RETRY_ATTEMPTS=3
# Number of retry attempts for failed requests (default: 3)
HIBP_USER_AGENT=PasswordStrengthChecker-Project
# User-Agent header for API requests (default: PasswordStrengthChecker-Project)
HIBP_API_BASE_URL=https://api.pwnedpasswords.com
# Base URL for HIBP API (default: https://api.pwnedpasswords.com)

# -----------------------------------------------------------------------------
# Batch Processing Configuration
# -----------------------------------------------------------------------------
DEFAULT_MAX_CONCURRENT=10
# Maximum concurrent API calls for batch operations (default: 10)
API_CALL_DELAY=0.1
# Delay between API calls in seconds (default: 0.1)

# -----------------------------------------------------------------------------
# Password Policy Configuration
# -----------------------------------------------------------------------------
MIN_PASSWORD_LENGTH=12
# Minimum required password length (default: 12)
DEFAULT_PASSWORD_LENGTH=16
# Default length for generated passwords (default: 16)
DEFAULT_PASSPHRASE_WORDS=4
# Default number of words for generated passphrases (default: 4)

# -----------------------------------------------------------------------------
# Character Sets for Password Generation
# -----------------------------------------------------------------------------
SPECIAL_CHARS=!@#$%^&*
# Special characters to use (default: !@#$%^&*)
AMBIGUOUS_CHARS=0O1lI
# Characters to exclude when avoid_ambiguous=True (default: 0O1lI)

# -----------------------------------------------------------------------------
# Strength Rating Thresholds (Entropy in bits)
# -----------------------------------------------------------------------------
ENTROPY_VERY_WEAK=28
ENTROPY_WEAK=36
ENTROPY_MODERATE=60
ENTROPY_STRONG=80
# Thresholds for password strength ratings based on entropy

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
SECURE_MEMORY_WIPE=true
# Whether to attempt secure memory clearing (default: true)

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------
QUIET_MODE=false
# Run with minimal output (default: false)